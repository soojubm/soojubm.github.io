{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "inlineSourceMap": true,
    "forceConsistentCasingInFileNames": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  }
}

